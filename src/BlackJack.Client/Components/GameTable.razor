@page "/table/{TableId}"
@inject GameHubService Hub
@inject NavigationManager Navigation
@implements IDisposable

<BankruptModal IsVisible="@showBankruptModal"
               IsRetrying="@isRetrying"
               IsLeaving="@isLeaving"
               OnRetry="RetryBankrupt"
               OnLeave="LeaveTable" />

<div class="game-table-container">
    <header class="game-header">
        <button class="btn-ghost text-sm" @onclick="LeaveTable">← Лобби</button>
        <div class="text-center game-header__title">
            <h1 class="font-display text-gold-gradient text-lg font-bold">@(_state?.Name ?? "Стол")</h1>
            <p class="text-xs text-casino-muted">@PhaseLabel(_state?.Phase ?? GamePhase.WaitingForPlayers)</p>
        </div>
        <div class="chip-badge">@(_me?.Chips ?? 0)</div>
    </header>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="game-banner game-banner--error">@errorMessage</div>
    }

    @if (_state?.LastEventMessage is not null)
    {
        <div class="game-banner game-banner--event">@_state.LastEventMessage</div>
    }

    <div class="game-table-stage">
        <div class="game-dealer-zone">
            <DealerHand Dealer="@(_state?.Dealer ?? new DealerDto())" Compact="true" />
        </div>

        @* Mobile: geometric layout by player count *@
        <div class="mobile-table-zone mobile-only">
            @if (_state is null || _me is null)
            {
                <div class="text-center text-casino-muted text-sm py-6">Подключение к столу...</div>
            }
            else
            {
                var playerCount = _state.Players.Count;
                <div class="mobile-table mobile-table--@playerCount">
                    @foreach (var slot in GetMobileSlots(_state.Players, playerCount))
                    {
                        var isMe = slot.Player.Id == _me.Id;
                        var isActive = _state.ActivePlayerId == slot.Player.Id;
                        <div class="mobile-table__slot mobile-table__slot--@slot.Position @(isMe ? "is-me" : "") @(isActive ? "is-active" : "")">
                            <PlayerHand PlayerName="@slot.Player.Name"
                                        Chips="@slot.Player.Chips"
                                        Hands="@slot.Player.Hands"
                                        ShowResults="@(_state.Phase == GamePhase.RoundComplete)"
                                        Phase="@_state.Phase"
                                        LastAction="@slot.Player.LastActionMessage"
                                        Compact="@(playerCount > 1)" />
                        </div>
                    }
                </div>
            }
        </div>

        @* Desktop: full 5-seat grid *@
        <div class="table-felt desktop-only">
            <div class="seat-grid">
                @if (_state is not null)
                {
                    @foreach (var seat in Enumerable.Range(0, TableState.MaxPlayers))
                    {
                        var player = _state.Players.FirstOrDefault(p => p.SeatIndex == seat);
                        <div class="seat-slot @(player is null ? "opacity-30" : "")">
                            @if (player is not null)
                            {
                                <PlayerHand PlayerName="@player.Name"
                                            Chips="@player.Chips"
                                            Hands="@player.Hands"
                                            ShowResults="@(_state.Phase == GamePhase.RoundComplete)"
                                            Phase="@_state.Phase"
                                            LastAction="@player.LastActionMessage" />
                            }
                            else
                            {
                                <div class="seat-empty">Свободное место</div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @* Fixed bottom dock: bets + actions always visible on mobile *@
    @if (_me is not null)
    {
        <div class="game-dock">
            <BettingPanel Phase="@(_state?.Phase ?? GamePhase.Betting)"
                          Chips="@_me.Chips"
                          CurrentBet="@_me.CurrentBet"
                          HasPlacedBet="@_me.HasPlacedBet"
                          IsBankrupt="@_me.IsBankrupt"
                          OnPlaceBet="PlaceBet" />

            @if (IsMyTurn && _activeHand is not null)
            {
                <div class="action-panel">
                    <button class="btn-emerald action-btn" @onclick="() => DoAction(GameAction.Hit)">Hit</button>
                    <button class="btn-gold action-btn" @onclick="() => DoAction(GameAction.Stand)">Stand</button>
                    @if (CanDouble)
                    {
                        <button class="btn-chip action-btn" @onclick="() => DoAction(GameAction.Double)">×2</button>
                    }
                    @if (CanSplit)
                    {
                        <button class="btn-chip action-btn" @onclick="() => DoAction(GameAction.Split)">Split</button>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string TableId { get; set; } = "";

    private TableStateDto? _state;
    private PlayerDto? _me;
    private HandDto? _activeHand;
    private string? errorMessage;
    private bool showBankruptModal;
    private bool isRetrying;
    private bool isLeaving;
    private bool IsMyTurn => _me is not null && _state?.ActivePlayerId == _me.Id;
    private bool CanDouble => _activeHand is not null && _me is not null &&
                              _activeHand.Cards.Count == 2 && _me.Chips >= _activeHand.Bet;
    private bool CanSplit => _activeHand is not null && _me is not null &&
                             _activeHand.Cards.Count == 2 &&
                             _activeHand.Cards[0].Rank == _activeHand.Cards[1].Rank &&
                             _me.Chips >= _activeHand.Bet;

    protected override async Task OnInitializedAsync()
    {
        Hub.TableUpdated += OnTableUpdated;
        Hub.ErrorReceived += OnError;

        try
        {
            await Hub.EnsureConnectedAsync();

            if (Hub.TableId != TableId || _state is null)
            {
                var dto = await Hub.JoinTableAsync(TableId);
                if (dto is null)
                {
                    Navigation.NavigateTo("/");
                    return;
                }
                UpdateState(dto);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OnTableUpdated(TableStateDto dto)
    {
        if (dto.Id == TableId)
            UpdateState(dto);
        InvokeAsync(StateHasChanged);
    }

    private void OnError(string msg)
    {
        errorMessage = msg;
        isRetrying = false;
        isLeaving = false;
        InvokeAsync(StateHasChanged);
    }

    private void UpdateState(TableStateDto dto)
    {
        _state = dto;
        _me = dto.Players.FirstOrDefault(p => p.Id == Hub.PlayerId)
              ?? dto.Players.FirstOrDefault(p => p.Name == Hub.PlayerName);

        if (_me is not null)
            Hub.PlayerId = _me.Id;

        showBankruptModal = _me?.IsBankrupt == true;
        _activeHand = _me is not null && _me.Hands.Count > _me.CurrentHandIndex
            ? _me.Hands[_me.CurrentHandIndex]
            : _me?.Hands.FirstOrDefault();
    }

    private async Task PlaceBet(int amount)
    {
        errorMessage = null;
        await Hub.PlaceBetAsync(amount);
    }

    private async Task DoAction(GameAction action)
    {
        errorMessage = null;
        await Hub.PlayerActionAsync(action);
    }

    private async Task RetryBankrupt()
    {
        isRetrying = true;
        await Hub.RetryAfterBankruptAsync();
        isRetrying = false;
    }

    private async Task LeaveTable()
    {
        isLeaving = true;
        await Hub.LeaveTableAsync();
        Navigation.NavigateTo("/");
    }

    private readonly record struct MobileSeatSlot(string Position, PlayerDto Player);

    private IEnumerable<MobileSeatSlot> GetMobileSlots(IReadOnlyList<PlayerDto> players, int count)
    {
        if (count <= 0 || _me is null)
            yield break;

        switch (count)
        {
            case 1:
                yield return new("center", _me);
                yield break;
            case 2:
                yield return new("top", _me);
                yield return new("bottom", players.First(p => p.Id != _me.Id));
                yield break;
            case 3:
            {
                var others = players.Where(p => p.Id != _me.Id).OrderBy(p => p.SeatIndex).ToList();
                yield return new("top", _me);
                yield return new("bl", others[0]);
                yield return new("br", others[1]);
                yield break;
            }
            default:
            {
                var ordered = players.OrderBy(p => p.SeatIndex).ToList();
                var positions = count switch
                {
                    4 => new[] { "tl", "tr", "bl", "br" },
                    5 => new[] { "tl", "tr", "bl", "bc", "br" },
                    _ => Array.Empty<string>()
                };

                for (var i = 0; i < ordered.Count && i < positions.Length; i++)
                    yield return new(positions[i], ordered[i]);
                yield break;
            }
        }
    }

    private static string PhaseLabel(GamePhase phase) => phase switch
    {
        GamePhase.Betting => "Фаза ставок",
        GamePhase.Dealing => "Раздача...",
        GamePhase.PlayerTurn => "Ход игроков",
        GamePhase.DealerTurn => "Ход дилера",
        GamePhase.Settlement => "Подсчёт",
        GamePhase.RoundComplete => "Раунд завершён",
        _ => "Ожидание игроков"
    };

    public void Dispose()
    {
        Hub.TableUpdated -= OnTableUpdated;
        Hub.ErrorReceived -= OnError;
    }
}